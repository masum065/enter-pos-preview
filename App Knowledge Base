## 🎨 Coding Patterns (MUST FOLLOW)

### API Route Pattern
```typescript
// GET with server-side search, filters, pagination
export async function GET(request: NextRequest) {
  const session = await getSession();
  const { searchParams } = new URL(request.url);
  
  // Filters as AND conditions
  const conditions = [];
  if (status) conditions.push(eq(table.status, status));
  if (search) conditions.push(or(ilike(table.name, `%${search}%`), ...));
  
  const whereClause = conditions.length > 0 ? and(...conditions) : undefined;
  
  // Filtered data
  const items = await db.select().from(table).where(whereClause).limit(limit).offset(offset);
  
  // Filtered count (for pagination)
  const totalCount = await db.select({ count: sql`count(*)` }).from(table).where(whereClause);
  
  // Status counts from ALL data (for tab badges)
  const statusCounts = await db.select({ status, count }).from(table).groupBy(status);
  
  return { items, pagination: { page, limit, total, totalPages }, stats: { statusCounts } };
}
```

### Hook Pattern
```typescript
interface Filters { search?: string; status?: string; page?: number; limit?: number; }

export function useEntities(filters: Filters = {}) {
  return useQuery({
    queryKey: ["entities", "list", filters],
    queryFn: async () => {
      const params: Record<string, string> = {};
      if (filters.search) params.search = filters.search;
      // ... pass all filters as URL params
      return apiClient.get("/api/entities", params);
    },
  });
}
```

### Frontend Page Pattern (URL-based filters)
```typescript
// URL as source of truth
const activeSearch = searchParams.get("search") || "";
const activeStatus = searchParams.get("status") || "";

// Search via form submit (not on every keystroke)
const [searchInput, setSearchInput] = useState(activeSearch);
const handleSearch = (e) => { /* push ?search=xxx */ };

// Status tabs with counts from API
{STATUS_OPTIONS.map((status) => (
  <button onClick={() => setStatus(status)}>
    {status} ({statusCounts[status] || 0})
  </button>
))}

// NO client-side filteredItems = useMemo(() => ...) on paginated data!
```

